generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  NOT_ANSWERED
  MEETING_FIXED
  CONTACT_IN_FUTURE
  CLOSED_WON
  CLOSED_LOST
  JUNK
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  name             String
  avatarUrl        String?
  emailVerified    Boolean? @default(false)
  rolePermissionId String   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rolePermission RolePermission @relation(fields: [rolePermissionId], references: [id])
  chats          Chat[]
  sessions       Session[]
  leads          Lead[]
  leadActivities LeadActivity[]

  @@index([email])
  @@map("users")
}

/** Better Auth session table */
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

/** Better Auth verification table */
model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model RolePermission {
  id          String   @id @default(uuid()) @db.Uuid
  role        UserRole
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users User[]

  @@map("role_permissions")
}

model Chat {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @db.Uuid
  title    String  @default("New Chat")
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("chats")
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @db.Uuid
  role        String
  parts       Json?
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([updatedAt])
  @@map("chat_messages")
}

model Lead {
  id String @id @default(cuid())
  customerName     String
  contactNumber    String
  alternateContact String?
  state String?
  city  String?
  platform        String
  status          LeadStatus        @default(NEW)
  temperature     LeadTemperature?
  leadCreatedDate DateTime
  followUpDate    DateTime?
  propertyType    String?
  serviceRequired String?
  budgetRange     String?
  propertySize    String?
  requirement     String? @db.Text
  initialNotes    String? @db.Text
  preferredCallTime String?
  visitChargeQuoted Decimal? @db.Decimal(10, 2)
  visitTokenAmount  Decimal? @db.Decimal(10, 2)
  userId String   @db.Uuid
  user   User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities LeadActivity[]

  @@index([status])
  @@index([userId])
  @@index([followUpDate])
  @@map("leads")
}

model LeadActivity {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  activityDate DateTime
  activityType String
  note         String? @db.Text

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([activityDate])
  @@map("lead_activities")
}
