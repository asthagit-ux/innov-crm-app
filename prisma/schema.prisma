generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  NOT_ANSWERED
  MEETING_FIXED
  CONTACT_IN_FUTURE
  CLOSED_WON
  CLOSED_LOST
  JUNK
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
  HOLD
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  name             String
  avatarUrl        String?
  emailVerified    Boolean? @default(false)
  password         String?
  rolePermissionId String   @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rolePermission RolePermission  @relation(fields: [rolePermissionId], references: [id])
  accounts       Account[]
  chats          Chat[]
  sessions       Session[]
  leads          Lead[]
  leadActivities LeadActivity[]
  assignedLeads  Lead[]          @relation("AssignedLeads")
  teamLeads      LeadTeamMember[]
  meetings       Meeting[]
  comments       Comment[]

  @@index([email])
  @@map("users")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @db.Uuid
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model RolePermission {
  id          String   @id @default(uuid()) @db.Uuid
  role        UserRole
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("role_permissions")
}

model Lead {
  id               String          @id @default(cuid())
  customerName     String
  contactNumber    String
  alternateContact String?
  email            String?
  state            String?
  city             String?
  platform         String
  leadSource       String?         @default("Meta Ads")
  status           LeadStatus      @default(NEW)
  temperature      LeadTemperature?
  activeStatus     ActiveStatus    @default(ACTIVE)
  assignedTo       String?         @db.Uuid
  leadCreatedDate  DateTime
  followUpDate     DateTime?
  propertyType     String?
  serviceRequired  String?
  briefScope       String?         @db.Text
  budgetRange      String?
  propertySize     String?
  requirement      String?         @db.Text
  initialNotes     String?         @db.Text
  preferredCallTime String?
  visitChargeQuoted Decimal?       @db.Decimal(10, 2)
  visitTokenAmount  Decimal?       @db.Decimal(10, 2)
  userId           String?         @db.Uuid
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user           User?            @relation(fields: [userId], references: [id])
  assignedUser   User?            @relation("AssignedLeads", fields: [assignedTo], references: [id])
  activities     LeadActivity[]
  teamMembers    LeadTeamMember[]
  meetings       Meeting[]
  comments       Comment[]

  @@index([status])
  @@index([userId])
  @@index([followUpDate])
  @@map("leads")
}

model LeadTeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, userId])
  @@map("lead_team_members")
}

model Meeting {
  id          String   @id @default(uuid()) @db.Uuid
  leadId      String
  userId      String?  @db.Uuid
  agenda      String
  meetingDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("meetings")
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String
  userId    String?  @db.Uuid
  content   String
  type      String   @default("note")
  createdAt DateTime @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("comments")
}

model Chat {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String   @default("New Chat")
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("chats")
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @db.Uuid
  role        String
  parts       Json?
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([updatedAt])
  @@map("chat_messages")
}

model LeadActivity {
  id           String   @id @default(cuid())
  leadId       String
  activityDate DateTime
  activityType String
  note         String?  @db.Text
  userId       String?  @db.Uuid
  createdAt    DateTime @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([activityDate])
  @@map("lead_activities")
}
